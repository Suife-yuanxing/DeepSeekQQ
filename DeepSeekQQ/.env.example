# ═══════════════════════════════════════════════════════════════
# DeepSeekQQ 最小必要配置
# 复制为 .env 后填入实际值即可启动
# 完整配置参考：.env.full.example
# ═══════════════════════════════════════════════════════════════

ENVIRONMENT=prod
HOST=127.0.0.1
PORT=8082
DRIVER=~fastapi+~httpx

# ===== 必填 =====
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ===== 推荐配置 =====
MY_QQ=your_qq_number_here

# ===== Admin 管理后台认证 (推荐设置) =====
# 生成随机 token: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=
