ENVIRONMENT=prod
HOST=127.0.0.1
PORT=8082
DRIVER=~fastapi+~httpx

# ===== DeepSeek LLM =====
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ===== 百度 TTS (语音合成) =====
BAIDU_TTS_AK=your_baidu_ak_here
BAIDU_TTS_SK=your_baidu_sk_here

# ===== 数据路径 =====
DEEPSEEK_DB_PATH=./data/chat_memory.db
DEEPSEEK_IMAGE_DIR=./data/images
DEEPSEEK_VOICE_DIR=./data/voice

# ===== 语音 =====
VOICE_ENABLED_PRIVATE=true
VOICE_ENABLED_GROUP=true
VOICE_CHANCE=0.10
VOICE_MAX_LENGTH=120
VOICE_TRY_CONVERT=true
VOICE_NAME=zh-CN-XiaomengNeural

TTS_ENGINE=baidu

# ===== 语音识别 (STT) =====
STT_ENABLED=true
STT_ENGINE=mimo   # mimo 或 baidu

# ===== 策略 =====
RANDOM_REPLY_CHANCE=0.05
MAX_MEMORY=30
SHARE_TTL=1800

MY_QQ=your_qq_number_here

# ===== 人设 =====
BOT_NAME=林念念
BOT_AGE=21
BOT_GENDER=女
BOT_HEIGHT=165
BOT_BIRTHDAY=6月15日
BOT_ZODIAC=双子座
BOT_CITY=上海
BOT_HOMETOWN=杭州
BOT_OCCUPATION=大学生
BOT_MAJOR=设计/数字媒体
BOT_CAT_NAME=团团

# ===== Token 预算 =====
API_MAX_TOKENS=1500
MAX_INPUT_TOKENS=28000
RESERVE_OUTPUT_TOKENS=2000
CHAT_HISTORY_MULTIPLIER=2

# ===== 搜索 =====
TAVILY_API_KEY=your_tavily_key_here

# ===== 图片生成 =====
IMAGE_GEN_API_KEY=your_image_gen_key_here
IMAGE_GEN_MODEL=dall-e-3

# ===== Qwen VL 视觉 =====
QWEN_VL_API_KEY=your_qwen_vl_key_here
QWEN_VL_MODEL=qwen-vl-max

# ===== GLM 视觉 =====
GLM_API_KEY=your_glm_key_here
GLM_MODEL=glm-4-flash
GLM_VISION_MODEL=glm-4v-flash

# ===== 火山引擎 TTS =====
VOLCANO_APP_ID=your_volcano_app_id
VOLCANO_ACCESS_TOKEN=your_volcano_token
VOLCANO_VOICE=zh_female_jiaochuannv_uranus_bigtts

# ===== MiMo TTS/STT =====
MIMO_API_KEY=your_mimo_key_here
MIMO_BASE_URL=https://api.mimo.com

# ===== 表情包 =====
STICKER_DIR=./data/stickers

# ===== 手机控制 (MCP) =====
PHONE_WS_KEY=pk_your_phone_key
PHONE_RELAY_PORT=8443

# ===== 提醒 =====
REMINDER_CHECK_INTERVAL=60

# ===== 深度思考 =====
THINK_THEN_SPEAK_ENABLED=false
THINK_MAX_TOKENS=500

# ===== 音乐 =====
MUSIC_ENABLED=true
MUSIC_VOICE_CHANCE=0.3
