{
  "mcpServers": {
    "glm-mcp": {
      "command": "uvx",
      "args": [
        "glm-mcp"
      ],
      "env": {
        "GLM_API_KEY": "${GLM_API_KEY}",
        "GLM_MODEL": "glm-4-flash"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@1"
      ]
    }
  }
}
