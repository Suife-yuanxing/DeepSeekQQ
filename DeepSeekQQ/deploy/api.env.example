# DeepSeek 用户侧 API（8766）环境变量模板
# 复制为 .api.env 并填入真实值（.api.env 不提交 git，已在 .gitignore）
#
# 生成强随机密钥：openssl rand -hex 32

# ── JWT 签名密钥（access 15min + refresh 7d）──
# 生产必须改！用 openssl rand -hex 32 生成
PLATFORM_JWT_SECRET=

# ── 手机号 AES-256-GCM 加密主密钥（任意字符串，内部 sha256 派生 32 字节）──
# 生产必须改！用 openssl rand -hex 32 生成
PLATFORM_PHONE_AES_KEY=

# ── API Key 加密主密钥（Task 1.3，同上）──
# 生产必须改！用 openssl rand -hex 32 生成
# ⚠️ 丢失此密钥 = 所有已存 API Key 密文不可逆，需重新录入
PLATFORM_APIKEY_AES_KEY=

# ── SMS 验证码（开发期固定 1234，生产对接服务商后删除此变量）──
PLATFORM_SMS_FIXED_CODE=1234

# ── 监听配置 ──
PLATFORM_API_HOST=0.0.0.0
PLATFORM_API_PORT=8766

# ── CORS（生产收紧为 App 域名，逗号分隔；开发期 * 允许所有）──
PLATFORM_CORS_ORIGINS=*

# ── 数据库路径（与 8082 bot 共享同一 SQLite，WAL 模式）──
DEEPSEEK_DB_PATH=./data/chat_memory.db
