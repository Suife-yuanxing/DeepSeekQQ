# ═══════════════════════════════════════════════════════════════
# DeepSeekQQ 完整配置参考
# ⚠️ 包含所有可选 API Key 字段名和格式，仅供管理员参考
# ⚠️ 生产环境请勿将实际 Key 写入此文件
# ═══════════════════════════════════════════════════════════════

ENVIRONMENT=prod
HOST=127.0.0.1
PORT=8082
DRIVER=~fastapi+~httpx

# ===== DeepSeek LLM (必填) =====
DEEPSEEK_API_KEY=sk-your_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ===== Kimi / Moonshot (可选) =====
KIMI_API_KEY=sk-your_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.6

# ===== MiniMax (可选, Council用) =====
MINIMAX_API_KEY=your_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3

# ===== Mimo Chat (可选, Council用) =====
MIMO_CHAT_API_KEY=your_key_here
MIMO_CHAT_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_CHAT_MODEL=mimo-v2.5-pro

# ===== Admin 管理后台认证 =====
# 生成随机 token: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# ===== 百度 TTS (语音合成) =====
BAIDU_TTS_AK=your_ak_here
BAIDU_TTS_SK=your_sk_here
BAIDU_TTS_PER=5118
BAIDU_TTS_SPD=5
BAIDU_TTS_PIT=5
BAIDU_TTS_VOL=5

# ===== MiMo TTS/STT =====
TTS_ENGINE=baidu
MIMO_API_KEY=your_key_here
MIMO_API_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_TTS_VOICE=冰糖

# ===== 语音识别 (STT) =====
STT_ENABLED=true
STT_ENGINE=mimo
MIMO_STT_API_KEY=your_key_here
MIMO_STT_API_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_STT_MODEL=whisper-1

# ===== 火山引擎 TTS =====
VOLCANO_APP_ID=your_app_id
VOLCANO_ACCESS_TOKEN=your_token
VOLCANO_VOICE_TYPE=zh_female_jiaochuannv_uranus_bigtts

# ===== Qwen VL 视觉识别 =====
QWEN_VL_API_KEY=your_key_here
QWEN_VL_MODEL=qwen-vl-plus

# ===== GLM (智谱AI, 免费视觉模型) =====
GLM_API_KEY=your_key_here
GLM_MODEL=glm-4-flash
GLM_VISION_MODEL=glm-4v-flash

# ===== 搜索 (Tavily) =====
TAVILY_API_KEY=your_key_here

# ===== 天气 (和风天气, 可选) =====
WEATHER_API_KEY=your_key_here
WEATHER_CITY=上海

# ===== 图片生成 (Agnes AI) =====
IMAGE_GEN_API_KEY=your_key_here
IMAGE_GEN_MODEL=agnes-image-2.1-flash

# ===== 手机控制 (MCP) =====
PHONE_WS_KEY=your_strong_key_min_16_chars
PHONE_RELAY_PORT=8765
PHONE_ALLOW_IPS=127.0.0.1

# ===== 人设 =====
BOT_NAME=林念念
BOT_AGE=21
BOT_GENDER=女
BOT_HEIGHT=165
BOT_BIRTHDAY=6月15日
BOT_ZODIAC=双子座
BOT_CITY=上海
BOT_HOMETOWN=杭州
BOT_OCCUPATION=大学生
BOT_MAJOR=设计/数字媒体
BOT_CAT_NAME=团团

# ===== 策略参数 =====
MY_QQ=your_qq_number
RANDOM_REPLY_CHANCE=0.05
MAX_MEMORY=30
SHARE_TTL=1800
MAX_REPLY_CHARS=900

# ===== Token 预算 =====
API_MAX_TOKENS=1500
MAX_INPUT_TOKENS=28000
RESERVE_OUTPUT_TOKENS=2000
SYSTEM_PROMPT_TOKEN_BUDGET=4000
MAX_USER_MSG_CHARS=800
CHAT_HISTORY_MULTIPLIER=2

# ===== 语音 =====
VOICE_ENABLED_PRIVATE=true
VOICE_ENABLED_GROUP=true
VOICE_CHANCE=0.10
VOICE_MAX_LENGTH=120
VOICE_TRY_CONVERT=true
VOICE_NAME=zh-CN-XiaomengNeural
VOICE_TOKEN=
VOICE_DEFAULT_STYLE=温柔甜美，自然可爱

# ===== 表情包 =====
STICKER_ENABLED=true
STICKER_DIR=./data/stickers

# ===== Ollama 本地模型 =====
OLLAMA_ENABLED=false

# ===== 深度思考 =====
THINK_THEN_SPEAK_ENABLED=false
THINK_MAX_TOKENS=500

# ===== 提醒 =====
REMINDER_ENABLED=true
REMINDER_CHECK_INTERVAL=60

# ===== 音乐 =====
MUSIC_ENABLED=true
MUSIC_VOICE_CHANCE=0.3

# ===== CORS =====
CORS_ALLOW_ORIGINS=
