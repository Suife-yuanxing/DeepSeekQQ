async def call_deepseek_api(messages: List[Dict[str, str]], temperature: float = 0.9) -> str:
    if not API_KEY:
        return "API密钥没配置好喵..."
    url = "https://api.deepseek.com/chat/completions"
    headers = {
        "Authorization": f"Bearer {API_KEY}",
        "Content-Type": "application/json"
    }
    payload = {
        "model": MODEL,
        "messages": messages,
        "temperature": temperature,
        "max_tokens": 800,
        "stream": False
    }
    try:
        async with aiohttp.ClientSession() as session:
            async with session.post(url, headers=headers, json=payload, timeout=aiohttp.ClientTimeout(total=60)) as resp:
                if resp.status != 200:
                    return f"API出错啦...状态码{resp.status}"
                data = await resp.json()
                content = data["choices"][0]["message"]["content"]
                content = re.sub(r'[（(].*?[）)]', '', content)
                content = re.sub(r'\*[^*]*\*', '', content)
                content = re.sub(r'【.*?】', '', content)
                return content.strip()
    except Exception as e:
        return f"网络抽风了...{str(e)[:50]}"


def _has_ffmpeg() -> bool:
    return shutil.which("ffmpeg") is not None


async def _convert_mp3_to_silk(mp3_path: str) -> Optional[str]:
    if not VOICE_TRY_CONVERT or not _has_ffmpeg():
        return None
    silk_path = mp3_path.replace(".mp3", ".silk")
    pcm_path = mp3_path.replace(".mp3", ".pcm")
    try:
        ffmpeg_pcm = [
            "ffmpeg", "-y", "-i", mp3_path,
            "-f", "s16le", "-ar", "24000", "-ac", "1",
            pcm_path
        ]
        proc1 = await asyncio.create_subprocess_exec(
            *ffmpeg_pcm,
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE
        )
        _, stderr1 = await proc1.communicate()
        if proc1.returncode != 0:
            print(f"[语音] ffmpeg pcm 转换失败: {stderr1.decode()[:200]}")
            return None
        silk_encoder = shutil.which("silk_v3_encoder") or shutil.which("silk_encoder")
        if not silk_encoder:
            print("[语音] 未找到 silk_v3_encoder，跳过 silk 编码")
            try:
                os.remove(pcm_path)
            except:
                pass
            return None
        enc_cmd = [silk_encoder, pcm_path, silk_path, "-tencent"]
        proc2 = await asyncio.create_subprocess_exec(
            *enc_cmd,
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE
        )
        _, stderr2 = await proc2.communicate()
        try:
            os.remove(pcm_path)
        except:
            pass
        if proc2.returncode == 0 and os.path.exists(silk_path) and os.path.getsize(silk_path) > 0:
            print(f"[语音] silk 转码成功: {silk_path}")
            return silk_path
        else:
            print(f"[语音] silk 编码失败: {stderr2.decode()[:200]}")
            return None
    except Exception as e:
        print(f"[语音] 转码异常: {e}")
        for p in [pcm_path, silk_path]:
            try:
                if os.path.exists(p):
                    os.remove(p)
            except:
                pass
        return None


async def generate_voice_file(text: str) -> Optional[str]:
    if len(text) > VOICE_MAX_LENGTH:
        print(f"[语音] 文本过长({len(text)}字)，跳过语音")
        return None
    try:
        communicate = edge_tts.Communicate(text, VOICE_NAME, rate="-5%")
        mp3_path = f"{VOICE_DIR}/deepseek_voice_{int(datetime.now().timestamp() * 1000)}.mp3"
        await communicate.save(mp3_path)
        print(f"[语音] edge-tts 生成成功: {mp3_path}")
        silk_path = await _convert_mp3_to_silk(mp3_path)
        if silk_path:
            try:
                os.remove(mp3_path)
            except:
                pass
            return silk_path
        return mp3_path
    except Exception as e:
        print(f"[语音] edge-tts 生成失败: {e}")
        return None


async def send_voice(bot: Bot, event: MessageEvent, text: str):
    is_group = isinstance(event, GroupMessageEvent)
    voice_enabled = VOICE_ENABLED.get("private" if not is_group else "group", False)
    if not voice_enabled:
        return
    voice_path = await generate_voice_file(text)
    if not voice_path:
        return
    if not os.path.exists(voice_path):
        print(f"[语音] 文件不存在: {voice_path}")
        return
    
    # 构造 HTTP URL，让 NapCat 通过 HTTP 下载语音文件
    filename = os.path.basename(voice_path)
    voice_url = f"http://{SERVER_HOST}:{SERVER_PORT}/voice/{filename}"
    
    try:
        print(f"[语音] 正在发送 URL: {voice_url}")
        await bot.send(event, MessageSegment.record(voice_url))
        print("[语音] 发送指令已提交")
    except Exception as e:
        print(f"[语音] 发送失败: {e}")
    finally:
        # 延迟30秒清理，给 NapCat 下载时间
        await asyncio.sleep(30)
        try:
            if os.path.exists(voice_path):
                os.remove(voice_path)
                print("[语音] 临时文件已清理")
        except Exception as clean_err:
            print(f"[语音] 清理临时文件失败: {clean_err}")


