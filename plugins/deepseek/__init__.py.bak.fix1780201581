def split_long_reply(text: str) -> List[str]:
    """按段落（空行分隔）拆分，每个段落单独发一条消息；超长段落按标点保护性拆分"""
    paragraphs = []
    current = []
    
    for line in text.split('\n'):
        stripped = line.strip()
        if stripped:
            current.append(stripped)
        else:
            if current:
                paragraphs.append('\n'.join(current))
                current = []
    
    if current:
        paragraphs.append('\n'.join(current))
    
    if len(paragraphs) <= 1:
        return [text.strip()]
    
    result = []
    for p in paragraphs:
        if len(p) > 120:
            parts = re.split(r'(。|\?|？|!|！)', p)
            temp = ""
            for part in parts:
                if not part:
                    continue
                if len(temp) + len(part) > 120 and temp:
                    result.append(temp.strip())
                    temp = part
                else:
                    temp += part
            if temp:
                result.append(temp.strip())
        else:
            result.append(p)
    
    return result


def estimate_reply_length(user_msg: str, history: List[Dict[str, Any]]) -> Dict[str, Any]:
    msg_len = len(user_msg.strip())
    is_short = msg_len <= REPLY_LENGTH_CONFIG["short_threshold"]
    is_question = any(kw in user_msg for kw in ["吗", "?", "？", "怎么", "为什么", "啥", "多少", "呢"])
    is_emotional = any(kw in user_msg for kw in ["累", "难过", "开心", "喜欢", "讨厌", "想", "爱", "抱", "亲", "哼", "呜", "想", "要"])
    is_continuation = len(history) >= 2 and history[-1]["role"] == "assistant"
    if is_short and not is_continuation:
        target = random.randint(1, 2)
        style = "简短随意"
    elif is_emotional:
        target = random.randint(2, 4)
        style = "情感倾诉"
    elif is_question:
        target = random.randint(2, 3)
        style = "认真回答"
    else:
        target = random.randint(1, 3)
        style = "自然闲聊"
    return {"target_lines": target, "style": style}


def build_system_prompt(affection: Dict[str, Any], mood: Dict[str, Any], length: Dict[str, Any]) -> str:
    addons = []
    if affection["score"] >= 500:
        addons.append("你对这个人非常亲密，会撒娇、主动关心、偶尔任性，语气很软。")
    elif affection["score"] >= 200:
        addons.append("你对这个人很有好感，愿意分享心事，偶尔会故意逗他。")
    elif affection["score"] >= 100:
        addons.append("你对这个人有点在意，态度温和，不再那么客气。")
    elif affection["score"] >= 50:
        addons.append("你对这个人不再陌生，偶尔会多聊几句，开始有点屑。")
    else:
        addons.append("你对这个人还比较客气，有点距离感，懒懒的。")
    if mood["score"] > 70:
        addons.append("你现在心情很好，话可能偏多，语气活泼轻快，可能会主动撩一下。")
    elif mood["score"] < 30:
        addons.append("你现在心情不太好，回复简短，有点冷淡或傲娇，嘴硬。")
    elif mood["mood"] == "傲娇":
        addons.append("你现在有点傲娇，嘴硬心软，明明在意却装作无所谓。")
    addons.append(f"【当前回复策略】{length['style']}，请分成{length['target_lines']}段回复，用换行分隔。不要一大段，要像真实聊天消息。")
    return SYSTEM_PROMPT + "\n\n【当前状态】\n" + "\n".join(addons)


