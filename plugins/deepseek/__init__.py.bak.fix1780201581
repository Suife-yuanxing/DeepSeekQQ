@chat_handler.handle()
async def handle_chat(bot: Bot, event: MessageEvent):
    raw_msg = event.get_message().extract_plain_text().strip()
    if not raw_msg:
        return
    is_group = isinstance(event, GroupMessageEvent)
    session_id = get_session_id(event)
    user_id = str(event.user_id)
    if is_group:
        is_at_me = event.is_tome()
        nicknames = ["猫娘", "kitty", "喵喵", "在吗", "bot", "机器人"]
        has_nickname = any(nick in raw_msg for nick in nicknames)
        should_reply = is_at_me or has_nickname or (random.random() < RANDOM_REPLY_CHANCE)
        if not should_reply:
            return
        if is_at_me:
            raw_msg = re.sub(r'\[CQ:at,qq=\d+\]', '', raw_msg).strip()
            if not raw_msg:
                raw_msg = "在吗"
    await update_affection(user_id, delta=random.uniform(0.5, 2.0))
    mood = await update_catgirl_mood(raw_msg)
    affection = await get_affection(user_id)
    await save_message(session_id, "user", raw_msg)
    memories = await get_recent_memories(session_id)
    length_info = estimate_reply_length(raw_msg, memories)
    sys_prompt = build_system_prompt(affection, mood, length_info)
    messages = [{"role": "system", "content": sys_prompt}]
    history_limit = REPLY_LENGTH_CONFIG["context_depth"] * 2
    for mem in memories[-history_limit:]:
        messages.append({"role": mem["role"], "content": mem["content"]})
    if not messages or messages[-1]["role"] != "user":
        messages.append({"role": "user", "content": raw_msg})
    reply_text = await call_deepseek_api(messages)
    await save_message(session_id, "assistant", reply_text)
    await trim_memories(session_id)
    send_as_voice = should_send_voice(raw_msg, reply_text, memories)
    if send_as_voice:
        print(f"[决策] 上下文判断发语音，跳过文字: {reply_text[:30]}...")
        await send_voice(bot, event, reply_text)
    else:
        print(f"[决策] 上下文判断发文字: {reply_text[:30]}...")
        parts = split_long_reply(reply_text)
        for i, part in enumerate(parts):
            if i > 0:
                await asyncio.sleep(random.uniform(1.0, 2.5))
            await bot.send(event, Message(part))


