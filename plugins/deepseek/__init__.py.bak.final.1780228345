# ==================== 分享内容理解 ====================
_recent_shares: Dict[str, List[Dict[str, Any]]] = {}
_SHARE_TTL = 1800  # 30分钟过期

async def fetch_url_content(url: str) -> Optional[Dict[str, str]]:
    """增强版网页抓取，按平台解析，返回结构化内容"""
    import hashlib
    cache_key = hashlib.md5(url.encode()).hexdigest()
    
    # 先查缓存
    try:
        async with aiosqlite.connect(DB_PATH) as db:
            async with db.execute(
                "SELECT title, author, summary, fetched_at FROM article_cache WHERE url_hash = ?",
                (cache_key,)
            ) as cursor:
                row = await cursor.fetchone()
                if row:
                    # 24小时内直接返回
                    if datetime.now().timestamp() - row[3] < 86400:
                        print(f"[分享] 命中缓存: {url[:60]}")
                        return {"title": row[0] or "无标题", "author": row[1] or "未知", "summary": row[2] or "", "cached": True}
    except Exception:
        pass
    
    headers = {
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
        "Accept-Language": "zh-CN,zh;q=0.9"
    }
    
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(url, headers=headers, timeout=aiohttp.ClientTimeout(total=20), allow_redirects=True) as resp:
                if resp.status != 200:
                    return None
                final_url = str(resp.url)
                html = await resp.text()
                
                # 平台专用解析
                result = _parse_by_platform(html, final_url)
                if not result:
                    # 通用解析 fallback
                    result = _parse_generic(html)
                
                if result and result.get("summary"):
                    # 存入缓存
                    try:
                        async with aiosqlite.connect(DB_PATH) as db:
                            await db.execute(
                                """INSERT OR REPLACE INTO article_cache 
                                (url_hash, url, title, author, summary, fetched_at) 
                                VALUES (?, ?, ?, ?, ?, ?)""",
                                (cache_key, url, result.get("title", ""), result.get("author", ""), 
                                 result["summary"][:2000], datetime.now().timestamp())
                            )
                            await db.commit()
                    except Exception as e:
                        print(f"[分享] 缓存写入失败: {e}")
                
                return result
                
    except Exception as e:
        print(f"[分享] 抓取失败 {url[:60]}: {e}")
        return None


def _parse_by_platform(html: str, url: str) -> Optional[Dict[str, str]]:
    """按平台解析"""
    # B站专栏
    if "bilibili.com/read" in url or "bilibili.com/opus" in url:
        title = re.search(r'<h1[^>]*class="[^"]*title[^"]*"[^>]*>(.*?)</h1>', html)
        title = re.sub(r'<[^>]+>', '', title.group(1)).strip() if title else "B站专栏"
        author = re.search(r'"name":"([^"]+)"', html)
        author = author.group(1) if author else "未知UP"
        # B站正文在 #read-article-holder 或 .opus-module-content
        content = re.search(r'<div[^>]*id="read-article-holder"[^>]*>(.*?)</div>\s*<div[^>]*class="[^"]*bottom-bar', html, re.DOTALL)
        if not content:
            content = re.search(r'<div[^>]*class="[^"]*opus-module-content[^"]*"[^>]*>(.*?)</div>', html, re.DOTALL)
        text = _clean_html(content.group(1)) if content else ""
        return {"title": title, "author": author, "summary": text[:1200], "cached": False}
    
    # 知乎
    if "zhihu.com" in url:
        title = re.search(r'<h1[^>]*class="[^"]*QuestionHeader-title[^"]*"[^>]*>(.*?)</h1>', html)
        if not title:
            title = re.search(r'<h1[^>]*class="[^"]*Post-Title[^"]*"[^>]*>(.*?)</h1>', html)
        title = re.sub(r'<[^>]+>', '', title.group(1)).strip() if title else "知乎文章"
        author = re.search(r'"author":"([^"]+)"', html) or re.search(r'<a[^>]*class="[^"]*AuthorInfo-name[^"]*"[^>]*>(.*?)</a>', html)
        author = re.sub(r'<[^>]+>', '', author.group(1)).strip() if author else "未知作者"
        content = re.search(r'<div[^>]*class="[^"]*RichContent-inner[^"]*"[^>]*>(.*?)</div>', html, re.DOTALL)
        if not content:
            content = re.search(r'<div[^>]*class="[^"]*Post-RichTextContainer[^"]*"[^>]*>(.*?)</div>', html, re.DOTALL)
        text = _clean_html(content.group(1)) if content else ""
        return {"title": title, "author": author, "summary": text[:1200], "cached": False}
    
    # 微信公众号
    if "mp.weixin.qq.com" in url:
        title = re.search(r'<h2[^>]*class="rich_media_title[^"]*"[^>]*>(.*?)</h2>', html, re.DOTALL)
        title = re.sub(r'<[^>]+>', '', title.group(1)).strip() if title else "公众号文章"
        author = re.search(r'<a[^>]*id="js_name"[^>]*>(.*?)</a>', html, re.DOTALL)
        author = re.sub(r'<[^>]+>', '', author.group(1)).strip() if author else "未知公众号"
        content = re.search(r'<div[^>]*class="rich_media_content[^"]*"[^>]*>(.*?)</div>', html, re.DOTALL)
        text = _clean_html(content.group(1)) if content else ""
        return {"title": title, "author": author, "summary": text[:1200], "cached": False}
    
    return None


def _parse_generic(html: str) -> Optional[Dict[str, str]]:
    """通用解析：基于文本密度提取正文"""
    # 移除脚本样式
    text = re.sub(r'<script.*?</script>', '', html, flags=re.DOTALL)
    text = re.sub(r'<style.*?</style>', '', text, flags=re.DOTALL)
    text = re.sub(r'<nav.*?</nav>', '', text, flags=re.DOTALL)
    text = re.sub(r'<footer.*?</footer>', '', text, flags=re.DOTALL)
    text = re.sub(r'<header.*?</header>', '', text, flags=re.DOTALL)
    
    # 尝试找 article 或 main 标签
    article = re.search(r'<article[^>]*>(.*?)</article>', text, re.DOTALL)
    if article:
        body = article.group(1)
    else:
        main = re.search(r'<main[^>]*>(.*?)</main>', text, re.DOTALL)
        body = main.group(1) if main else text
    
    # 提取标题
    title = re.search(r'<title[^>]*>(.*?)</title>', html, re.DOTALL)
    title = re.sub(r'<[^>]+>', '', title.group(1)).strip() if title else "无标题"
    
    # 清洗正文
    clean = _clean_html(body)
    # 如果太短，可能是提取失败，尝试整个 body
    if len(clean) < 200:
        body_match = re.search(r'<body[^>]*>(.*?)</body>', html, re.DOTALL)
        if body_match:
            clean = _clean_html(body_match.group(1))
    
    return {"title": title[:100], "author": "未知", "summary": clean[:1200], "cached": False}


def _clean_html(html_fragment: str) -> str:
    """清洗 HTML 片段为纯文本"""
    if not html_fragment:
        return ""
    # 保留段落和换行
    text = html_fragment.replace('</p>', '
').replace('</div>', '
').replace('</br>', '
').replace('<br>', '
')
    # 移除所有标签
    text = re.sub(r'<[^>]+>', '', text)
    # 解码实体
    text = text.replace('&nbsp;', ' ').replace('&quot;', '"').replace('&amp;', '&').replace('&lt;', '<').replace('&gt;', '>')
    # 清理空白
    text = re.sub(r'\n\s*\n', '
', text)
    text = re.sub(r'[ \t]+', ' ', text)
    text = '\n'.join(line.strip() for line in text.split('\n') if line.strip())
    return text.strip()


def _cleanup_expired_shares(session_id: str):
    """清理过期分享缓存"""
    if session_id not in _recent_shares:
        return
    now = datetime.now().timestamp()
    _recent_shares[session_id] = [
        s for s in _recent_shares[session_id]
        if now - s.get("time", 0) < _SHARE_TTL
    ][-5:]
    if not _recent_shares[session_id]:
        del _recent_shares[session_id]


async def extract_and_cache_shares(event: MessageEvent, session_id: str) -> bool:
    """检测消息中的链接、图片、卡片，提取内容并缓存"""
    msg = event.get_message()
    shares = []

    for seg in msg:
        if seg.type == "text":
            text = seg.data.get("text", "")
            urls = re.findall(r'https?://[^\s\]\)]+', text)
            for url in urls:
                url = url.rstrip('.,;:!?)]}\'\"')
                article = await fetch_url_content(url)
                if article and article.get("summary"):
                    display = f"{article.get('title', '无标题')} - {article.get('author', '未知')}"
                    shares.append({
                        "type": "网页",
                        "source": display,
                        "url": url,
                        "summary": article["summary"],
                        "cached": article.get("cached", False),
                        "time": datetime.now().timestamp()
                    })

        elif seg.type == "image":
            shares.append({
                "type": "图片",
                "source": seg.data.get("url") or seg.data.get("file", "未知图片"),
                "summary": "[图片内容暂无法直接识别]",
                "time": datetime.now().timestamp()
            })

        elif seg.type == "json":
            try:
                card = json.loads(seg.data.get("data", "{}"))
                meta = card.get("meta", {})
                for k, v in meta.items():
                    if isinstance(v, dict):
                        title = v.get("title", "分享卡片")
                        desc = v.get("desc", "") or v.get("description", "")
                        jump = v.get("jumpUrl", "") or v.get("url", "")
                        shares.append({
                            "type": "分享卡片",
                            "source": title,
                            "summary": f"{desc} {jump}".strip()[:500],
                            "time": datetime.now().timestamp()
                        })
                        break
            except Exception:
                pass

        elif seg.type == "xml":
            raw = seg.data.get("data", "")
            shares.append({
                "type": "分享消息",
                "source": "XML消息",
                "summary": raw[:300],
                "time": datetime.now().timestamp()
            })

        elif seg.type == "file":
            shares.append({
                "type": "文件",
                "source": seg.data.get("name", "未知文件"),
                "summary": f"大小: {seg.data.get('size', '?')} 字节",
                "time": datetime.now().timestamp()
            })

    if shares:
        if session_id not in _recent_shares:
            _recent_shares[session_id] = []
        _recent_shares[session_id].extend(shares)
        _cleanup_expired_shares(session_id)
        print(f"[分享] 缓存了 {len(shares)} 条内容: {[s['type'] for s in shares]}")
        return True
    return False


def format_shares_for_prompt(shares: List[Dict[str, Any]]) -> str:
    """将分享内容格式化为 Prompt 片段"""
    if not shares:
        return ""
    lines = ["【用户最近分享的外部内容】"]
    for i, s in enumerate(shares[-3:], 1):
        lines.append(f"{i}. [{s['type']}] {s['source']}")
        if s.get('summary'):
            lines.append(f"   摘要: {s['summary'][:400]}")
    lines.append("注意：如果用户接下来的问题与上述内容明显相关，请基于这些内容结合上下文回答；如果不相关，请正常聊天，不必刻意提及。")
    return "\n".join(lines)


def _extract_keywords(text: str) -> set:
    """简单关键词提取，用于文章关联判断"""
    # 取前100字的高频词（去掉常见虚词）
    stopwords = {"的", "了", "是", "在", "我", "有", "和", "就", "不", "人", "都", "一", "一个", "上", "也", "很", "到", "说", "要", "去", "你", "会", "着", "没有", "看", "好", "自己", "这", "那"}
    words = re.findall(r'[\u4e00-\u9fa5]{2,6}', text[:500])
    return set(w for w in words if w not in stopwords and len(w) > 1)


def _check_articles_related(shares: List[Dict[str, Any]]) -> bool:
    """检查最近的多篇文章是否有关联"""
    if len(shares) < 2:
        return False
    # 取最近两篇
    texts = [s.get("summary", "") for s in shares[-2:]]
    if len(texts) < 2 or not all(texts):
        return False
    kw1 = _extract_keywords(texts[0])
    kw2 = _extract_keywords(texts[1])
    if not kw1 or not kw2:
        return False
    # 交集比例
    intersection = kw1 & kw2
    return len(intersection) >= 3 or (len(intersection) / min(len(kw1), len(kw2))) > 0.15


def build_analysis_prompt(shares: List[Dict[str, Any]], user_question: str) -> str:
    """构建专业分析模式的 Prompt，支持多文章联动"""
    if not shares:
        return ""
    
    # 判断是否需要联动
    is_related = _check_articles_related(shares)
    target_shares = shares[-2:] if is_related else shares[-1:]
    
    # 构建内容块
    content_blocks = []
    for i, s in enumerate(target_shares, 1):
        block = f"【内容{i}】类型：{s.get('type', '未知')} | 来源：{s.get('source', '未知')}\n摘要：{s.get('summary', '')[:600]}"
        content_blocks.append(block)
    
    relation_hint = ""
    if is_related and len(target_shares) > 1:
        relation_hint = "\n注意：上述两篇内容有关联，请做对比分析或联动解读，指出它们的共同点和差异。"
    
    prompt = f"""【分析任务】用户分享了 {len(target_shares)} 个内容，请基于以下材料回答用户问题。

{'\n\n'.join(content_blocks)}
{relation_hint}

用户的问题：{user_question}

要求：
1. 先基于上述材料做客观、有条理的分析（分点或分段）
2. 分析要具体，引用材料中的细节和数据，不要泛泛而谈
3. {'如果有多篇内容，请做对比或联动分析，不要孤立看待每篇' if is_related else '聚焦核心论点，深入剖析'}
4. 分析完后，用你猫娘的语气做一句简短个性化点评（调侃、吐槽、认同都可以）
5. 整体语气仍然是你在聊天，但分析部分要专业、有信息量、有深度
6. 如果材料不足以下结论，请诚实说明，不要编造"""
    return prompt


async def init_db():
    async with aiosqlite.connect(DB_PATH) as db:
        await db.execute("""
            CREATE TABLE IF NOT EXISTS memories (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                session_id TEXT NOT NULL,
                role TEXT NOT NULL,
                content TEXT NOT NULL,
                timestamp REAL NOT NULL
            )
        """)
        await db.execute("""
            CREATE TABLE IF NOT EXISTS affection (
                user_id TEXT PRIMARY KEY,
                score REAL DEFAULT 0,
                level INTEGER DEFAULT 1,
                title TEXT DEFAULT "陌生人",
                last_interaction REAL,
                total_chats INTEGER DEFAULT 0,
                streak_days INTEGER DEFAULT 0,
                last_streak_date TEXT
            )
        """)
        await db.execute("""
            CREATE TABLE IF NOT EXISTS catgirl_mood (
                id INTEGER PRIMARY KEY CHECK (id = 1),
                mood TEXT DEFAULT "平淡",
                score REAL DEFAULT 50,
                last_updated REAL
            )
        """)
        await db.execute(
            "INSERT OR IGNORE INTO catgirl_mood (id, mood, score, last_updated) VALUES (1, '平淡', 50, ?)",
            (datetime.now().timestamp(),)
        )
        await db.execute("""
            CREATE TABLE IF NOT EXISTS memory_tags (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id TEXT NOT NULL,
                tag_type TEXT NOT NULL,
                content TEXT NOT NULL,
                weight REAL DEFAULT 1.0,
                created_at REAL,
                last_used REAL,
                UNIQUE(user_id, tag_type, content)
            )
        """)
        await db.execute("""
            CREATE TABLE IF NOT EXISTS memory_summaries (
                session_id TEXT PRIMARY KEY,
                summary TEXT,
                key_moments TEXT,
                updated_at REAL
            )
        """)
        await db.execute("CREATE INDEX IF NOT EXISTS idx_memories_session ON memories(session_id, timestamp)")
        await db.execute("CREATE INDEX IF NOT EXISTS idx_memories_role ON memories(role, timestamp)")
        await db.execute("""
            CREATE TABLE IF NOT EXISTS article_cache (
                url_hash TEXT PRIMARY KEY,
                url TEXT NOT NULL,
                title TEXT,
                author TEXT,
                summary TEXT,
                fetched_at REAL
            )
        """)
        await db.commit()


def get_session_id(event: MessageEvent) -> str:
    if isinstance(event, PrivateMessageEvent):
        return f"private_{event.user_id}"
    return f"group_{event.group_id}"


AFFECTION_LEVELS = [
    (0, "陌生人"),
    (20, "认识的人"),
    (50, "有点在意"),
    (100, "喜欢的人"),
    (200, "重要的人"),
    (500, "专属主人"),
    (1000, "命定之人"),
]


async def get_affection(user_id: str) -> Dict[str, Any]:
    async with aiosqlite.connect(DB_PATH) as db:
        async with db.execute(
            "SELECT score, level, title, total_chats, streak_days FROM affection WHERE user_id = ?",
            (str(user_id),)
        ) as cursor:
            row = await cursor.fetchone()
            if not row:
                return {"score": 0, "level": 1, "title": "陌生人", "total_chats": 0, "streak_days": 0}
            return {
                "score": row[0],
                "level": row[1],
                "title": row[2],
                "total_chats": row[3],
                "streak_days": row[4],
            }


async def update_affection(user_id: str, delta: float = 1.0):
    async with aiosqlite.connect(DB_PATH) as db:
        now = datetime.now()
        today = now.strftime("%Y-%m-%d")
        async with db.execute(
            "SELECT score, total_chats, streak_days, last_streak_date FROM affection WHERE user_id = ?",
            (str(user_id),)
        ) as cursor:
            row = await cursor.fetchone()
        if not row:
            await db.execute(
                """INSERT INTO affection
                (user_id, score, level, title, last_interaction, total_chats, streak_days, last_streak_date)
                VALUES (?, ?, 1, ?, ?, 1, 1, ?)""",
                (str(user_id), delta, AFFECTION_LEVELS[0][1], now.timestamp(), today)
            )
        else:
            score, total_chats, streak_days, last_streak = row
            new_score = max(0, score + delta)
            new_total = total_chats + 1
            if last_streak == today:
                new_streak = streak_days
            elif last_streak == (now - timedelta(days=1)).strftime("%Y-%m-%d"):
                new_streak = streak_days + 1
            else:
                new_streak = 1
            new_level = 1
            new_title = AFFECTION_LEVELS[0][1]
            for threshold, title in AFFECTION_LEVELS:
                if new_score >= threshold:
                    new_level = AFFECTION_LEVELS.index((threshold, title)) + 1
                    new_title = title
            await db.execute(
                """UPDATE affection
                SET score = ?, level = ?, title = ?, last_interaction = ?,
                    total_chats = ?, streak_days = ?, last_streak_date = ?
                WHERE user_id = ?""",
                (new_score, new_level, new_title, now.timestamp(), new_total, new_streak, today, str(user_id))
            )
        await db.commit()


async def get_catgirl_mood() -> Dict[str, Any]:
    async with aiosqlite.connect(DB_PATH) as db:
        async with db.execute("SELECT mood, score FROM catgirl_mood WHERE id = 1") as cursor:
            row = await cursor.fetchone()
            return {"mood": row[0], "score": row[1]}


async def update_catgirl_mood(user_msg: str) -> Dict[str, Any]:
    happy = ["开心", "喜欢", "爱", "棒", "可爱", "喵", "亲", "抱", "摸摸", "乖", "嘿嘿", "哈哈", "想", "好", "乖"]
    sad = ["累", "难过", "伤心", "哭", "烦", "滚", "讨厌", "傻", "笨", "坏", "丑"]
    delta = 5 if any(w in user_msg for w in happy) else -3 if any(w in user_msg for w in sad) else 0
    async with aiosqlite.connect(DB_PATH) as db:
        async with db.execute("SELECT score FROM catgirl_mood WHERE id = 1") as cursor:
            row = await cursor.fetchone()
            new_score = max(0, min(100, row[0] + delta + random.randint(-2, 2)))
        mood = "开心" if new_score > 70 else "平淡" if new_score > 40 else "傲娇" if new_score > 20 else "生气"
        await db.execute(
            "UPDATE catgirl_mood SET mood = ?, score = ?, last_updated = ? WHERE id = 1",
            (mood, new_score, datetime.now().timestamp())
        )
        await db.commit()
        return {"mood": mood, "score": new_score}


async def save_message(session_id: str, role: str, content: str):
    async with aiosqlite.connect(DB_PATH) as db:
        await db.execute(
            "INSERT INTO memories (session_id, role, content, timestamp) VALUES (?, ?, ?, ?)",
            (session_id, role, content, datetime.now().timestamp())
        )
        await db.commit()


async def get_recent_memories(session_id: str, limit: int = MAX_MEMORY) -> List[Dict[str, Any]]:
    async with aiosqlite.connect(DB_PATH) as db:
        db.row_factory = aiosqlite.Row
        async with db.execute(
            "SELECT role, content, timestamp FROM memories WHERE session_id = ? ORDER BY timestamp DESC LIMIT ?",
            (session_id, limit)
        ) as cursor:
            rows = await cursor.fetchall()
            return [{"role": row["role"], "content": row["content"], "timestamp": row["timestamp"]} for row in reversed(rows)]


async def trim_memories(session_id: str, keep: int = MAX_MEMORY):
    async with aiosqlite.connect(DB_PATH) as db:
        await db.execute(
            """DELETE FROM memories WHERE session_id = ?
               AND id NOT IN (
                   SELECT id FROM memories WHERE session_id = ? ORDER BY timestamp DESC LIMIT ?
               )""",
            (session_id, session_id, keep)
        )
        await db.commit()


async def summarize_and_compress(session_id: str):
    """当记忆过多时，将早期对话压缩为摘要"""
    async with aiosqlite.connect(DB_PATH) as db:
        db.row_factory = aiosqlite.Row
        async with db.execute(
            "SELECT COUNT(*) as cnt FROM memories WHERE session_id = ?",
            (session_id,)
        ) as cursor:
            row = await cursor.fetchone()
            if row["cnt"] < 25:
                return
        async with db.execute(
            """SELECT role, content FROM memories
               WHERE session_id = ? ORDER BY timestamp ASC LIMIT 15""",
            (session_id,)
        ) as cursor:
            old_rows = await cursor.fetchall()
        if len(old_rows) < 10:
            return
        dialog = "\n".join([f"{r['role']}：{r['content'][:100]}" for r in old_rows])
        prompt = f"""请用一两句话总结以下对话的核心内容（用户关心什么、你们聊了什么重点），不要细节，只留框架：

{dialog}

摘要："""
        messages = [
            {"role": "system", "content": "你是一个对话摘要助手，只输出摘要文本，不要任何其他内容。"},
            {"role": "user", "content": prompt}
        ]
        summary = await call_deepseek_api(messages, temperature=0.5)
        summary = summary.strip()[:300]
        now = datetime.now().timestamp()
        await db.execute(
            """INSERT INTO memory_summaries (session_id, summary, key_moments, updated_at)
               VALUES (?, ?, ?, ?)
               ON CONFLICT(session_id) DO UPDATE SET
               summary = summary || ' | ' || ?, updated_at = ?""",
            (session_id, summary, "[]", now, summary, now)
        )
        async with db.execute(
            """SELECT id FROM memories WHERE session_id = ? ORDER BY timestamp DESC LIMIT 20""",
            (session_id,)
        ) as cursor:
            keep_ids = [str(r["id"]) for r in await cursor.fetchall()]
        if keep_ids:
            placeholders = ",".join(["?"] * len(keep_ids))
            await db.execute(
                f"DELETE FROM memories WHERE session_id = ? AND id NOT IN ({placeholders})",
                (session_id, *keep_ids)
            )
        await db.commit()
        print(f"[记忆] 会话 {session_id} 已压缩，摘要：{summary[:60]}...")


async def _extract_memory_tags(user_id: str, session_id: str, user_msg: str, reply_text: str):
    """后台任务：从对话中提取关键记忆"""
    if not isinstance(session_id, str) or not session_id.startswith("private_"):
        if not any(k in user_msg + reply_text for k in ["喜欢", "讨厌", "怕", "不吃", "名字", "生日", "住", "工作", "专业"]):
            return
    prompt = f"""从以下对话中，提取关于用户的客观关键信息（偏好、事实、禁忌、情绪）。
只输出 JSON 数组，不要有任何其他文字。没有就输出空数组 []。

用户说：{user_msg}
你回复：{reply_text}

示例输出：
[
  {{"type": "preference", "content": "用户喜欢喝冰美式"}},
  {{"type": "fact", "content": "用户养了一只叫橘子的猫"}},
  {{"type": "taboo", "content": "用户讨厌被叫全名"}}
]"""
    try:
        messages = [
            {"role": "system", "content": "你是一个对话记忆提取助手，只输出JSON数组。"},
            {"role": "user", "content": prompt}
        ]
        raw = await call_deepseek_api(messages, temperature=0.3)
        clean = re.sub(r'```json\s*|\s*```', '', raw).strip()
        tags = json.loads(clean)
        if not isinstance(tags, list):
            return
        async with aiosqlite.connect(DB_PATH) as db:
            now = datetime.now().timestamp()
            for tag in tags:
                t_type = tag.get("type", "fact")
                content_text = tag.get("content", "").strip()
                if not content_text or len(content_text) > 200:
                    continue
                await db.execute(
                    """INSERT INTO memory_tags (user_id, tag_type, content, weight, created_at, last_used)
                       VALUES (?, ?, ?, 1.0, ?, ?)
                       ON CONFLICT(user_id, tag_type, content)
                       DO UPDATE SET weight = weight + 0.2, last_used = ?""",
                    (str(user_id), t_type, content_text, now, now, now)
                )
            await db.commit()
            print(f"[记忆] 提取并保存了 {len(tags)} 条标签")
    except Exception as e:
        print(f"[记忆] 提取失败（非关键错误）: {e}")


async def _get_relevant_memories(user_id: str, session_id: str, current_msg: str, limit: int = 5) -> List[str]:
    """检索与当前话题相关的长期记忆"""
    try:
        async with aiosqlite.connect(DB_PATH) as db:
            db.row_factory = aiosqlite.Row
            now = datetime.now().timestamp()
            async with db.execute(
                """SELECT tag_type, content, weight, last_used FROM memory_tags
                   WHERE user_id = ? AND (tag_type IN ('preference', 'fact', 'taboo') OR weight > 1.2)
                   ORDER BY weight DESC, last_used DESC LIMIT ?""",
                (str(user_id), limit)
            ) as cursor:
                rows = await cursor.fetchall()
            memories = []
            for row in rows:
                days_ago = (now - row["last_used"]) / 86400
                if days_ago > 7 and row["weight"] < 1.5:
                    continue
                memories.append(f"[你记得关于TA的事：{row['content']}]")
            async with db.execute(
                "SELECT summary FROM memory_summaries WHERE session_id = ?",
                (session_id,)
            ) as cursor:
                summary_row = await cursor.fetchone()
                if summary_row and summary_row["summary"]:
                    memories.insert(0, f"[之前聊过的：{summary_row['summary'][:150]}]")
            return memories
    except Exception as e:
        print(f"[记忆] 检索失败: {e}")
        return []


async def call_deepseek_api(messages: List[Dict[str, str]], temperature: float = 0.9) -> str:
    if not API_KEY:
        return "API密钥没配置好喵..."
    url = "https://api.deepseek.com/chat/completions"
    headers = {
        "Authorization": f"Bearer {API_KEY}",
        "Content-Type": "application/json"
    }
    payload = {
        "model": MODEL,
        "messages": messages,
        "temperature": temperature,
        "max_tokens": 800,
        "stream": False
    }
    try:
        async with aiohttp.ClientSession() as session:
            async with session.post(url, headers=headers, json=payload, timeout=aiohttp.ClientTimeout(total=60)) as resp:
                if resp.status != 200:
                    return f"API出错啦...状态码{resp.status}"
                data = await resp.json()
                content = data["choices"][0]["message"]["content"]
                content = re.sub(r'[（(].*?[）)]', '', content)
                content = re.sub(r'\*[^*]*\*', '', content)
                content = re.sub(r'【.*?】', '', content)
                return content.strip()
    except Exception as e:
        return f"网络抽风了...{str(e)[:50]}"


def _has_ffmpeg() -> bool:
    return shutil.which("ffmpeg") is not None


async def _convert_mp3_to_silk(mp3_path: str) -> Optional[str]:
    if not VOICE_TRY_CONVERT or not _has_ffmpeg():
        return None
    silk_path = mp3_path.replace(".mp3", ".silk")
    pcm_path = mp3_path.replace(".mp3", ".pcm")
    try:
        ffmpeg_cmd = [
            "ffmpeg", "-y", "-i", mp3_path,
            "-f", "s16le", "-ar", "24000", "-ac", "1",
            pcm_path
        ]
        proc1 = await asyncio.create_subprocess_exec(
            *ffmpeg_cmd,
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE
        )
        _, stderr1 = await proc1.communicate()
        if proc1.returncode != 0:
            print(f"[语音] ffmpeg pcm 转换失败: {stderr1.decode()[:200]}")
            return None
        silk_encoder = "/usr/local/bin/silk_v3_encoder" if os.path.exists("/usr/local/bin/silk_v3_encoder") else (shutil.which("silk_v3_encoder") or shutil.which("silk_encoder"))
        if not silk_encoder:
            print("[语音] 未找到 silk_v3_encoder，跳过 silk 编码")
            try:
                os.remove(pcm_path)
            except:
                pass
            return None
        enc_cmd = [silk_encoder, pcm_path, silk_path, "-tencent"]
        proc2 = await asyncio.create_subprocess_exec(
            *enc_cmd,
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.PIPE
        )
        _, stderr2 = await proc2.communicate()
        try:
            os.remove(pcm_path)
        except:
            pass
        if proc2.returncode == 0 and os.path.exists(silk_path) and os.path.getsize(silk_path) > 0:
            print(f"[语音] silk 转码成功: {silk_path}")
            return silk_path
        else:
            print(f"[语音] silk 编码失败: {stderr2.decode()[:200]}")
            return None
    except Exception as e:
        print(f"[语音] 转码异常: {e}")
        for p in [pcm_path, silk_path]:
            try:
                if os.path.exists(p):
                    os.remove(p)
            except:
                pass
        return None


async def _get_baidu_token() -> str:
    global BAIDU_TTS_TOKEN
    if BAIDU_TTS_TOKEN:
        return BAIDU_TTS_TOKEN
    url = f"https://aip.baidubce.com/oauth/2.0/token?grant_type=client_credentials&client_id={BAIDU_TTS_AK}&client_secret={BAIDU_TTS_SK}"
    async with aiohttp.ClientSession() as session:
        async with session.get(url) as resp:
            data = await resp.json()
            BAIDU_TTS_TOKEN = data.get("access_token", "")
            return BAIDU_TTS_TOKEN


async def generate_voice_file(text: str) -> Optional[str]:
    if len(text) > VOICE_MAX_LENGTH:
        print(f"[语音] 文本过长({len(text)}字)，跳过语音")
        return None
    try:
        token = await _get_baidu_token()
        if not token:
            print("[语音] 百度 Token 获取失败")
            return None
        tex = urllib.parse.quote(text)
        tts_url = f"https://tsn.baidu.com/text2audio?tex={tex}&tok={token}&cuid=deepseek_bot&ctp=1&lan=zh&spd=5&pit=5&vol=5&per=5118&aue=3"
        mp3_path = f"{VOICE_DIR}/deepseek_voice_{int(datetime.now().timestamp() * 1000)}.mp3"
        async with aiohttp.ClientSession() as session:
            async with session.get(tts_url) as resp:
                data = await resp.read()
                if len(data) < 1000 or data[:2] == b'{"':
                    print(f"[语音] 百度TTS错误/无效: {data[:200]}")
                    return None
                with open(mp3_path, "wb") as f:
                    f.write(data)
        if os.path.exists(mp3_path) and os.path.getsize(mp3_path) > 1000:
            print(f"[语音] 百度TTS(度小萌-精品)生成成功: {mp3_path} ({os.path.getsize(mp3_path)} bytes)")
            return mp3_path
        print("[语音] 文件过小或不存在")
        return None
    except Exception as e:
        print(f"[语音] 百度TTS失败: {e}")
        return None


async def _delayed_cleanup(path: str, delay: int = 300):
    """后台延迟清理文件，不阻塞消息发送"""
    await asyncio.sleep(delay)
    try:
        if os.path.exists(path):
            os.remove(path)
            print(f"[语音] 已清理: {path}")
    except Exception as e:
        print(f"[语音] 清理失败: {e}")


async def send_voice(bot: Bot, event: MessageEvent, text: str):
    is_group = isinstance(event, GroupMessageEvent)
    voice_enabled = VOICE_ENABLED.get("private" if not is_group else "group", False)
    if not voice_enabled:
        return
    voice_path = await generate_voice_file(text)
    if not voice_path or not os.path.exists(voice_path):
        print("[语音] 无有效语音文件")
        return
    try:
        with open(voice_path, "rb") as vf:
            audio_bytes = vf.read()
            b64 = base64.b64encode(audio_bytes).decode()
        await bot.send(event, MessageSegment.record(file=f"base64://{b64}"))
        print(f"[语音] base64 直发 ({len(audio_bytes)} bytes)")
    except Exception as e:
        print(f"[语音] 发送失败: {e}")
    finally:
        asyncio.create_task(_delayed_cleanup(voice_path))


def should_send_voice(user_msg: str, reply_text: str, history: List[Dict[str, Any]]) -> bool:
    if "语音测试" in user_msg:
        return True
    if random.random() >= VOICE_CHANCE:
        return False
    if len(reply_text) > VOICE_MAX_LENGTH:
        return False
    if len(user_msg.strip()) <= 3:
        return True
    voice_friendly = ["喵", "哼", "呜", "嘛", "呀", "呢", "啦", "哦", "嗯"]
    if any(w in user_msg for w in voice_friendly):
        return True
    emotional = ["想", "喜欢", "爱", "抱", "亲", "乖", "摸摸"]
    if any(w in user_msg for w in emotional):
        return True
    return random.random() < 0.3


def split_long_reply(text: str) -> List[str]:
    """按段落（空行分隔）拆分，每个段落单独发一条消息；超长段落按标点保护性拆分"""
    paragraphs = []
    current = []
    for line in text.split('\n'):
        stripped = line.strip()
        if stripped:
            current.append(stripped)
        else:
            if current:
                paragraphs.append('\n'.join(current))
                current = []
    if current:
        paragraphs.append('\n'.join(current))
    if len(paragraphs) <= 1:
        return [text.strip()]
    result = []
    for p in paragraphs:
        if len(p) > 120:
            parts = re.split(r'(。|\?|？|!|！)', p)
            temp = ""
            for part in parts:
                if not part:
                    continue
                if len(temp) + len(part) > 120 and temp:
                    result.append(temp.strip())
                    temp = part
                else:
                    temp += part
            if temp:
                result.append(temp.strip())
        else:
            result.append(p)
    return result


def estimate_reply_length(user_msg: str, history: List[Dict[str, Any]]) -> Dict[str, Any]:
    msg_len = len(user_msg.strip())
    is_short = msg_len <= REPLY_LENGTH_CONFIG["short_threshold"]
    is_question = any(kw in user_msg for kw in ["吗", "?", "？", "怎么", "为什么", "啥", "多少", "呢"])
    is_emotional = any(kw in user_msg for kw in ["累", "难过", "开心", "喜欢", "讨厌", "想", "爱", "抱", "亲", "哼", "呜", "想", "要"])
    is_continuation = len(history) >= 2 and history[-1]["role"] == "assistant"
    if is_short and not is_continuation:
        target = random.randint(1, 2)
        style = "简短随意"
    elif is_emotional:
        target = random.randint(2, 4)
        style = "情感倾诉"
    elif is_question:
        target = random.randint(2, 3)
        style = "认真回答"
    else:
        target = random.randint(1, 3)
        style = "自然闲聊"
    return {"target_lines": target, "style": style}


def build_system_prompt(affection: Dict[str, Any], mood: Dict[str, Any], length: Dict[str, Any], relevant_memories: List[str] = None, recent_shares: List[Dict[str, Any]] = None) -> str:
    addons = []
    if affection["score"] >= 500:
        addons.append("你对这个人非常亲密，会撒娇、主动关心、偶尔任性，语气很软。")
    elif affection["score"] >= 200:
        addons.append("你对这个人很有好感，愿意分享心事，偶尔会故意逗他。")
    elif affection["score"] >= 100:
        addons.append("你对这个人有点在意，态度温和，不再那么客气。")
    elif affection["score"] >= 50:
        addons.append("你对这个人不再陌生，偶尔会多聊几句，开始有点屑。")
    else:
        addons.append("你对这个人还比较客气，有点距离感，懒懒的。")
    if mood["score"] > 70:
        addons.append("你现在心情很好，话可能偏多，语气活泼轻快，可能会主动撩一下。")
    elif mood["score"] < 30:
        addons.append("你现在心情不太好，回复简短，有点冷淡或傲娇，嘴硬。")
    elif mood["mood"] == "傲娇":
        addons.append("你现在有点傲娇，嘴硬心软，明明在意却装作无所谓。")
    addons.append(f"【当前回复策略】{length['style']}，请分成{length['target_lines']}段回复，用换行分隔。不要一大段，要像真实聊天消息。")
    memory_prompt = ""
    if relevant_memories:
        snippets = relevant_memories[:3]
        if snippets:
            memory_prompt = "\n\n【你突然想起的一些事】\n" + "\n".join(snippets) + "\n不要刻意提'我记得'，像自然想到一样偶尔带一句。"
    share_prompt = format_shares_for_prompt(recent_shares) if recent_shares else ""
    # 日常模式下分享内容仅作背景参考，不强制分析
    return SYSTEM_PROMPT + "\n\n【当前状态】\n" + "\n".join(addons) + memory_prompt + ("\n\n" + share_prompt if share_prompt else "")


chat_handler = on_message(priority=5, block=False)


@chat_handler.handle()
async def handle_chat(bot: Bot, event: MessageEvent):
    raw_msg = event.get_message().extract_plain_text().strip()
    session_id = get_session_id(event)
    has_share = await extract_and_cache_shares(event, session_id)
    if not raw_msg and not has_share:
        return
    if not raw_msg and has_share:
        is_group_tmp = isinstance(event, GroupMessageEvent)
        if not is_group_tmp or event.is_tome() or random.random() < 0.3:
            await bot.send(event, Message("喵？这是...让我看看~"))
        return
    is_group = isinstance(event, GroupMessageEvent)
    session_id = get_session_id(event)
    user_id = str(event.user_id)
    if is_group:
        is_at_me = event.is_tome()
        nicknames = ["猫娘", "kitty", "喵喵", "在吗", "bot", "机器人"]
        has_nickname = any(nick in raw_msg for nick in nicknames)
        should_reply = is_at_me or has_nickname or (random.random() < RANDOM_REPLY_CHANCE)
        if not should_reply:
            return
        if is_at_me:
            raw_msg = re.sub(r'\[CQ:at,qq=\d+\]', '', raw_msg).strip()
            if not raw_msg:
                raw_msg = "在吗"
    sad_words = ["累", "难过", "伤心", "哭", "烦", "滚", "讨厌", "傻", "笨", "坏", "丑"]
    happy_words = ["开心", "喜欢", "爱", "棒", "可爱", "喵", "亲", "抱", "摸摸", "乖", "嘿嘿", "哈哈", "想", "好"]
    if any(w in raw_msg for w in sad_words):
        delta = random.uniform(-1.5, -0.5)
    elif any(w in raw_msg for w in happy_words):
        delta = random.uniform(1.0, 2.5)
    else:
        delta = random.uniform(0.5, 1.5)
    await update_affection(user_id, delta=delta)
    mood = await update_catgirl_mood(raw_msg)
    affection = await get_affection(user_id)
    await save_message(session_id, "user", raw_msg)
    recent_memories = await get_recent_memories(session_id)
    relevant_tags = await _get_relevant_memories(user_id, session_id, raw_msg)
    if len(recent_memories) > 20:
        asyncio.create_task(summarize_and_compress(session_id))
    length_info = estimate_reply_length(raw_msg, recent_memories)
    shares_now = _recent_shares.get(session_id, [])
    
    # 检测用户是否在询问分享内容（专业分析模式）
    analysis_keywords = ["怎么看", "怎么讲", "分析一下", "评价", "观点", "有什么想法", "说说", "讲讲", "如何理解", "什么意思"]
    is_asking_analysis = any(kw in raw_msg for kw in analysis_keywords) and shares_now
    
    if is_asking_analysis:
        # 专业模式：用分析 Prompt 替代系统 Prompt
        analysis_prompt = build_analysis_prompt(shares_now, raw_msg)
        sys_prompt = SYSTEM_PROMPT + "\n\n【当前状态】\n" + "\n".join([
            "你对这个人" + ("非常亲密" if affection["score"] >= 500 else "很有好感" if affection["score"] >= 200 else "有点在意" if affection["score"] >= 100 else "不再陌生" if affection["score"] >= 50 else "还比较客气") + "。",
            f"你现在{mood['mood']}，回复{'活泼轻快' if mood['score'] > 70 else '简短冷淡' if mood['score'] < 30 else '自然'}。",
            "【当前回复策略】专业分析+个性点评，分析部分结构化、有深度，点评部分保持你的猫娘语气。"
        ])
        messages = [{"role": "system", "content": sys_prompt}]
        # 把分析任务作为用户消息注入
        messages.append({"role": "user", "content": analysis_prompt})
    else:
        # 日常模式
        sys_prompt = build_system_prompt(affection, mood, length_info, relevant_tags, shares_now)
        messages = [{"role": "system", "content": sys_prompt}]
    history_limit = REPLY_LENGTH_CONFIG["context_depth"] * 2
    for mem in recent_memories[-history_limit:]:
        messages.append({"role": mem["role"], "content": mem["content"]})
    if not messages or messages[-1]["role"] != "user":
        messages.append({"role": "user", "content": raw_msg})
    reply_text = await call_deepseek_api(messages)
    await save_message(session_id, "assistant", reply_text)
    await trim_memories(session_id)
    asyncio.create_task(_extract_memory_tags(user_id, session_id, raw_msg, reply_text))
    send_as_voice = should_send_voice(raw_msg, reply_text, recent_memories)
    if send_as_voice:
        print(f"[决策] 上下文判断发语音，跳过文字: {reply_text[:30]}...")
        await send_voice(bot, event, reply_text)
    else:
        print(f"[决策] 上下文判断发文字: {reply_text[:30]}...")
        parts = split_long_reply(reply_text)
        for i, part in enumerate(parts):
            if i > 0:
                await asyncio.sleep(random.uniform(1.0, 2.5))
            await bot.send(event, Message(part))


driver = get_driver()


@driver.on_startup
async def on_start():
    os.makedirs(VOICE_DIR, exist_ok=True)
    await init_db()
    try:
        from fastapi import FastAPI
        from fastapi.responses import FileResponse
        app = driver.server_app
        if app and isinstance(app, FastAPI):
            @app.get("/voice/{filename}")
            async def serve_voice(filename: str):
                file_path = os.path.join(VOICE_DIR, filename)
                if not os.path.abspath(file_path).startswith(os.path.abspath(VOICE_DIR)):
                    return {"error": "invalid path"}
                if os.path.exists(file_path):
                    return FileResponse(file_path, media_type="audio/mpeg")
                return {"error": "not found"}
            print(f"   语音文件服务已挂载: http://{SERVER_HOST}:{SERVER_PORT}/voice/")
    except Exception as e:
        print(f"   语音文件服务挂载失败: {e}")
    has_ff = _has_ffmpeg()
    print(f"✅ DeepSeek猫娘插件已启动~ 喵！")
    print(f"   ffmpeg 检测: {'已安装 ✅' if has_ff else '未安装 ❌ 语音可能无法发送'}")
    print(f"   语音开关: 私聊={VOICE_ENABLED.get('private')}, 群聊={VOICE_ENABLED.get('group')}")
    print(f"   语音触发概率: {VOICE_CHANCE * 100}%")
