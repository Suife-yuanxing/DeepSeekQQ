ENVIRONMENT=prod
HOST=127.0.0.1
PORT=8082
DRIVER=~fastapi+~httpx

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 百度 TTS
BAIDU_TTS_AK=your_baidu_ak_here
BAIDU_TTS_SK=your_baidu_sk_here

# 路径
DEEPSEEK_DB_PATH=/home/ubuntu/DeepSeekQQ/data/chat_memory.db
DEEPSEEK_VOICE_DIR=/home/ubuntu/DeepSeekQQ/data/voice

# 语音
VOICE_ENABLED_PRIVATE=true
VOICE_ENABLED_GROUP=true
VOICE_CHANCE=0.10
VOICE_MAX_LENGTH=120

# TTS 引擎选择: "baidu"（默认）或 "mimo"（小米 MiMo，免费+支持情绪风格）
TTS_ENGINE=baidu
# MiMo TTS 配置（TTS_ENGINE=mimo 时生效）
# MIMO_API_KEY=your_mimo_api_key_here
# MIMO_API_BASE_URL=https://api.xiaomimimo.com/v1
# MIMO_TTS_VOICE=冰糖  # 可选: 冰糖/茉莉/苏打/白桦

# 语音识别 (STT) - 使用百度语音识别API，与TTS共用AK/SK
STT_ENABLED=true

# 策略
RANDOM_REPLY_CHANCE=0.05
MAX_MEMORY=30
SHARE_TTL=1800

MY_QQ=your_qq_number_here

# 音乐功能
MUSIC_ENABLED=true
MUSIC_VOICE_CHANCE=0.3
