{
  "mcpServers": {
    "ollama-vision": {
      "command": "npx",
      "args": ["-y", "ollama-mcp-server"],
      "env": {
        "OLLAMA_HOST": "http://localhost:11434"
      }
    },
    "glm-mcp": {
      "command": "uvx",
      "args": ["glm-mcp"],
      "env": {
        "GLM_API_KEY": "${GLM_API_KEY}",
        "GLM_MODEL": "glm-4-flash"
      }
    }
  }
}
