# ============================================================
# Council Skill — 环境变量配置（示例）
# 复制为 .env 或配置为系统环境变量
# 优先级：系统环境变量 > Skill 目录 .env
# ⚠️ 此文件不含真实 Key，仅为示例。实际 Key 存于 .env（gitignore）
# ============================================================

# ── DeepSeek ──
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# ── Kimi（Moonshot） ──
KIMI_API_KEY=sk-xxx
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.6

# ── MiniMax ──
MINIMAX_API_KEY=sk-xxx
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# ── Mimo Chat ──
MIMO_CHAT_API_KEY=sk-xxx
MIMO_CHAT_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_CHAT_MODEL=mimo-v2.5-pro

# ── 裁决模型（Round 3 专用） ──
COUNCIL_JUDGE_MODEL=deepseek-v4-pro
COUNCIL_JUDGE_BASE_URL=https://api.deepseek.com/v1
COUNCIL_JUDGE_API_KEY=sk-xxx
# 如果裁决模型与 DeepSeek 共享 Key，可留空，脚本会 fallback 到 DEEPSEEK_API_KEY
